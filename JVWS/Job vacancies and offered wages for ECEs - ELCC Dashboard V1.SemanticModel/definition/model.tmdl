model Model
	culture: en-CA
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-CA
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 1

annotation PBI_QueryOrder = ["Unzip","JVWS","JVWS Characteristics","LFS Labour Force Occupation"]

annotation PBI_ProTooling = ["DevMode"]

ref table JVWS
ref table 'JVWS Characteristics'
ref table 'LFS Labour Force Occupation'
ref table DateTable

ref cultureInfo en-CA

