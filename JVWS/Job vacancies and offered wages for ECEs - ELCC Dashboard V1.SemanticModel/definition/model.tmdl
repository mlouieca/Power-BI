model Model
	culture: en-CA
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-CA
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 1

annotation PBI_QueryOrder = ["Unzip","JVWS","JVWS Characteristics","LFS Labour Force Occupation","Annual ECE Employment"]

annotation PBI_ProTooling = ["DevMode"]

ref table JVWS
ref table DateTable
ref table 'JVWS Characteristics'
ref table 'LFS Labour Force Occupation'
ref table 'Annual ECE Employment'

ref cultureInfo en-CA

