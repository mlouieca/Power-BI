	measure 'Job Vacancies (Quarter Avg)' = ```
			
			AVERAGEX(
			    VALUES(DateTable[Date]),
			    [Job Vacancies]
			)
			
			```
		lineageTag: 0f1ffac3-08a0-483c-ad1b-ca4bdfee400a

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Job Vacancies (Base 2019 Q1)' = ```
			
			CALCULATE(
			    [Job Vacancies (Quarter Avg)],
			    REMOVEFILTERS(DateTable),
			    DateTable[Year] = 2019,
			    DateTable[QuarterNumber] = 1
			)
			
			```
		lineageTag: 90eb6c42-2ed6-4cdc-90f8-7ecebd119402

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Job Vacancies Index (2019 Q1)' = ```
			
			VAR BaseVal = [Job Vacancies (Base 2019 Q1)]
			VAR CurrVal = [Job Vacancies (Quarter Avg)]
			RETURN
			IF(
			    ISBLANK(BaseVal),
			    BLANK(),
			    100 * DIVIDE(CurrVal, BaseVal)
			)
			
			```
		lineageTag: 44828418-9aed-4c0e-b8c7-1fa143427801

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Returns the YoY percent-change measure selected by the JVWS Statistics slicer. Supports job vacancies and average offered hourly wage.
	measure 'Selected YoY Change %' =
			VAR _Statistic = SELECTEDVALUE('JVWS'[Statistics], "Job vacancies")
			RETURN
			    SWITCH(
			        _Statistic,
			        "Average offered hourly wage", [Avg Wage (YoY %)],
			        "Job vacancies", [Job Vacancies (YoY %)],
			        BLANK()
			    )
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: YoY Analysis
		lineageTag: f1e45152-a55d-4d51-bf0c-48e3a9406c86

