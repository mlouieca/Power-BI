	measure 'Job Vacancies' = ```
			
			CALCULATE(
			    SUM('JVWS'[VALUE]),
			    'JVWS'[Statistics] = "Job vacancies"
			)
			
			```
		lineageTag: 8882ed90-b211-4186-858d-604a769febac

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Avg Offered Hourly Wage' = ```
			
			CALCULATE(
			    AVERAGE('JVWS'[VALUE]),
			    'JVWS'[Statistics] = "Average offered hourly wage"
			)
			
			```
		lineageTag: 3c1a530f-f514-499a-bba4-4ba7e8b26598

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Job Vacancies (MoM Abs - Latest)' = ```
			
			VAR _LatestDate = [Latest Month]
			VAR _PrevDate   = EDATE(_LatestDate, -1)
			VAR _LatestVal =
			    CALCULATE([Job Vacancies], TREATAS({_LatestDate}, DateTable[Date]))
			VAR _PrevVal =
			    CALCULATE([Job Vacancies], TREATAS({_PrevDate}, DateTable[Date]))
			RETURN
			_LatestVal - _PrevVal
			
			```
		lineageTag: af2f6806-5ded-44c7-881f-2f632c76f7b0

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Job Vacancies (MoM %)' = ```
			
			VAR Prev =
			    CALCULATE(
			        [Job Vacancies],
			        DATEADD(DateTable[Date], -1, MONTH)
			    )
			RETURN
			DIVIDE([Job Vacancies] - Prev, Prev)
			
			```
		lineageTag: a64aa2f6-2860-42e1-aab7-d7fe1b21277b

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Job Vacancies (YoY Abs)' =
			VAR _Current = [Job Vacancies]
			VAR _PrevYear =
			    CALCULATE(
			        [Job Vacancies],
			        DATEADD(DateTable[Date], -12, MONTH)
			    )
			RETURN
			    IF(
			        ISBLANK(_Current) || ISBLANK(_PrevYear),
			        BLANK(),
			        _Current - _PrevYear
			    )
		lineageTag: 578f1bbd-76fb-4ae6-a60d-3058a2d30c27

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Job Vacancies (YoY %)' =
			VAR _Current = [Job Vacancies]
			VAR _PrevYear =
			    CALCULATE(
			        [Job Vacancies],
			        DATEADD(DateTable[Date], -12, MONTH)
			    )
			RETURN
			    IF(
			        ISBLANK(_Current) || ISBLANK(_PrevYear),
			        BLANK(),
			        DIVIDE(_Current - _PrevYear, _PrevYear)
			    )
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 825f2c72-51a6-4ee3-9fc8-3a4fe8930f8b

