			```
		formatString: 0
		lineageTag: 57258633-da1a-4f00-8a60-4c0a6b7a7103
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	partition DateTable = calculated
		mode: import
		source = ```
				
				VAR MinDate = DATE(YEAR(MIN('JVWS'[Date])), MONTH(MIN('JVWS'[Date])), 1)
				VAR MaxDate = DATE(YEAR(MAX('JVWS'[Date])), MONTH(MAX('JVWS'[Date])), 1)
				RETURN
				ADDCOLUMNS(
				    CALENDAR(MinDate, EOMONTH(MaxDate, 0)),
				    "Year", YEAR([Date]),
				    "MonthNum", MONTH([Date]),
				    "Month", FORMAT([Date], "MMM"),
				    "YearMonth", FORMAT([Date], "YYYY-MM")
				)
				
				```

	annotation PBI_Id = 84afd30825e44706ad1ca9051a2e997d

