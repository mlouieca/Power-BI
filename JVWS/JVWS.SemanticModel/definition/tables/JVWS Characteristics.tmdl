table 'JVWS Characteristics'
	lineageTag: 18dc06b6-e4e5-40b2-a577-eb750208820c

	measure 'Characteristic Job Vacancies' = ```
			
			CALCULATE(
			    SUM('JVWS Characteristics'[VALUE]),
			    'JVWS Characteristics'[Statistics] = "Job vacancies"
			)
			
			```
		lineageTag: a9a8e715-03b8-462b-88a0-3bc065c7e2ea

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Characteristic Job Vacancies (Latest)' = ```
			
			VAR _LatestDate = [Characteristic Latest Month]
			RETURN
			CALCULATE(
			    [Characteristic Job Vacancies],
			    TREATAS({_LatestDate}, DateTable[Date])
			)
			
			```
		lineageTag: 2c7d6d32-6c25-42ea-8ac8-7fc88cf6778f

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Characteristic Proportion of Vacancies' = ```
			
			CALCULATE(
			    AVERAGE('JVWS Characteristics'[VALUE]),
			    'JVWS Characteristics'[Statistics] = "Proportion of job vacancies"
			)
			
			```
		formatString: 0.0
		lineageTag: 1926ec86-2df9-4b4e-83e4-09de65c786c4

	measure 'Characteristic Proportion of Vacancies (Latest)' = ```
			
			VAR _LatestDate = [Characteristic Latest Month]
			RETURN
			CALCULATE(
			    [Characteristic Proportion of Vacancies],
			    TREATAS({_LatestDate}, DateTable[Date])
			)
			
			```
		formatString: 0.0
		lineageTag: 7252aa49-5d1f-45b1-9ae9-96b68d423e32

	measure 'Characteristic Latest Month' = ```
			
			CALCULATE(
			    MAX('JVWS Characteristics'[Date]),
			    REMOVEFILTERS(DateTable)
			)
			
			```
		formatString: General Date
		lineageTag: e2b85071-f5b8-4def-8db3-4a2977ebd858

