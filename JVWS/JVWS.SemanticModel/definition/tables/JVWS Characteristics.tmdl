	partition 'JVWS Characteristics' = m
		mode: import
		source =
				let
				    Source = Web.Contents("https://www150.statcan.gc.ca/n1/tbl/csv/14100443-eng.zip"),
				    Custom1 = Unzip(Source),
				    Content = Custom1{0}[Content],
				    #"Imported CSV" = Csv.Document(Content,[Delimiter=",", Columns=17, Encoding=65001, QuoteStyle=QuoteStyle.None]),
				    #"Promoted Headers" = Table.PromoteHeaders(#"Imported CSV", [PromoteAllScalars=true]),
				    #"Changed Type" = Table.TransformColumnTypes(#"Promoted Headers",{{"REF_DATE", type date}, {"GEO", type text}, {"DGUID", type text}, {"National Occupational Classification", type text}, {"Job vacancy characteristics", type text}, {"Statistics", type text}, {"UOM", type text}, {"UOM_ID", Int64.Type}, {"SCALAR_FACTOR", type text}, {"SCALAR_ID", Int64.Type}, {"VECTOR", type text}, {"COORDINATE", type text}, {"VALUE", type number}, {"STATUS", type text}, {"SYMBOL", type text}, {"TERMINATED", type text}, {"DECIMALS", Int64.Type}}),
				    #"Filtered Characteristics" = Table.SelectRows(#"Changed Type", each List.Contains({
				        "Full-time",
				        "Part-time",
				        "Less than 1 year",
				        "1 year to less than 3 years",
				        "3 years to less than 5 years",
				        "5 years to less than 8 years",
				        "8 years or more",
				        "Less than 15 days",
				        "15 to 29 days",
				        "30 to 59 days",
				        "60 to 89 days",
				        "90 to 119 days",
				        "120 days or more"
				    }, [Job vacancy characteristics])),
				    #"Removed Columns" = Table.RemoveColumns(#"Filtered Characteristics",{"UOM", "UOM_ID", "SCALAR_FACTOR", "SCALAR_ID", "VECTOR", "COORDINATE", "STATUS", "SYMBOL", "TERMINATED", "DECIMALS", "DGUID"}),
				    #"Renamed Columns" = Table.RenameColumns(#"Removed Columns",{{"REF_DATE", "Date"}}),
				    #"Inserted Text Between Delimiters" = Table.AddColumn(#"Renamed Columns", "NOC_5", each try Text.BetweenDelimiters([National Occupational Classification], "[", "]") otherwise null, type text),
				    #"Filtered Occupation" = Table.SelectRows(#"Inserted Text Between Delimiters", each [NOC_5] = "42202"),
				    #"Added Occupation Label" = Table.AddColumn(#"Filtered Occupation", "Occupation Label", each Text.BeforeDelimiter([National Occupational Classification], " [") & " (" & [NOC_5] & ")", type text),
				    #"Added Characteristic Group" = Table.AddColumn(#"Added Occupation Label", "Characteristic Group", each
				        if List.Contains({"Full-time", "Part-time"}, [Job vacancy characteristics]) then "Full-time or part-time"
				        else if List.Contains({"Less than 15 days", "15 to 29 days", "30 to 59 days", "60 to 89 days", "90 to 119 days", "120 days or more"}, [Job vacancy characteristics]) then "Duration of job vacancy"
				        else if List.Contains({"Less than 1 year", "1 year to less than 3 years", "3 years to less than 5 years", "5 years to less than 8 years", "8 years or more"}, [Job vacancy characteristics]) then "Minimum experience level sought"
				        else "Other",
				        type text
				    ),
				    #"Added Characteristic Sort" = Table.AddColumn(#"Added Characteristic Group", "Characteristic Sort", each
				        if [Job vacancy characteristics] = "Full-time" then 1
				        else if [Job vacancy characteristics] = "Part-time" then 2
				        else if [Job vacancy characteristics] = "Less than 1 year" then 11
				        else if [Job vacancy characteristics] = "1 year to less than 3 years" then 12
				        else if [Job vacancy characteristics] = "3 years to less than 5 years" then 13
				        else if [Job vacancy characteristics] = "5 years to less than 8 years" then 14
				        else if [Job vacancy characteristics] = "8 years or more" then 15
				        else if [Job vacancy characteristics] = "Less than 15 days" then 21
				        else if [Job vacancy characteristics] = "15 to 29 days" then 22
				        else if [Job vacancy characteristics] = "30 to 59 days" then 23
				        else if [Job vacancy characteristics] = "60 to 89 days" then 24
				        else if [Job vacancy characteristics] = "90 to 119 days" then 25
				        else if [Job vacancy characteristics] = "120 days or more" then 26
				        else 99,
				        Int64.Type
				    )
				in
				    #"Added Characteristic Sort"

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

