table 'SEPH Hourly Earnings'
	lineageTag: 5b1b866c-57f3-4540-a91c-766dc78e12b6

	measure 'Hourly Earnings Value' =
			
			MAX ( 'SEPH Hourly Earnings'[VALUE] )
		lineageTag: 50acafaf-c6c4-43d3-acb2-fa92312057d1

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Child Care Avg Hourly Earnings' =
			
			CALCULATE (
			    [Hourly Earnings Value],
			    'SEPH Hourly Earnings'[NAICS] = "Child day-care services [6244]",
			    'SEPH Hourly Earnings'[Overtime] = "Including overtime"
			)
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: dc53ff27-2a64-4067-82f3-312ac41176a3

	measure 'All Industries Avg Hourly Earnings' =
			
			CALCULATE (
			    [Hourly Earnings Value],
			    'SEPH Hourly Earnings'[NAICS] = "Industrial aggregate excluding unclassified businesses [11-91N]",
			    'SEPH Hourly Earnings'[Overtime] = "Including overtime"
			)
		lineageTag: 69d50d80-6fd7-48ef-ae31-9c3a986967e3

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Child Care Hourly Earnings Gap' =
			
			[Child Care Avg Hourly Earnings] - [All Industries Avg Hourly Earnings]
		lineageTag: 13f66a37-9b83-49dc-9775-66e928dea008

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Child Care Hourly Earnings Relative to All Industries' =
			
			DIVIDE (
			    [Child Care Avg Hourly Earnings],
			    [All Industries Avg Hourly Earnings]
			)
		lineageTag: e5b34114-6788-4559-a8af-9e4e2a47ccf8

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Child Care Hourly Earnings YoY %' =
			
			VAR CurrentValue = [Child Care Avg Hourly Earnings]
			VAR PreviousValue =
			    CALCULATE (
			        [Child Care Avg Hourly Earnings],
			        DATEADD ( 'Date'[Date], -1, YEAR )
			    )
			RETURN
			    DIVIDE ( CurrentValue - PreviousValue, PreviousValue )
		lineageTag: 86a72d82-c056-4bcd-bc91-05cde9b1bba6

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'All Industries Hourly Earnings YoY %' =
			
			VAR CurrentValue = [All Industries Avg Hourly Earnings]
			VAR PreviousValue =
			    CALCULATE (
			        [All Industries Avg Hourly Earnings],
			        DATEADD ( 'Date'[Date], -1, YEAR )
			    )
			RETURN
			    DIVIDE ( CurrentValue - PreviousValue, PreviousValue )
		lineageTag: 2427639e-2d77-4459-ac78-3e40a583c0cc

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Child Care Hourly Earnings YoY % Latest' =
			
			VAR LatestYear = [Latest SEPH Year]
			RETURN
			    CALCULATE (
			        [Child Care Hourly Earnings YoY %],
			        FILTER (
			            ALL ( 'Date'[Date] ),
			            'Date'[Date] = LatestYear
			        )
			    )
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: d0e01d15-8b71-4159-ad20-3be19cb14a62

	measure 'All Industries Hourly Earnings YoY % Latest' =
			
			VAR LatestYear = [Latest SEPH Year]
			RETURN
			    CALCULATE (
			        [All Industries Hourly Earnings YoY %],
			        FILTER (
			            ALL ( 'Date'[Date] ),
			            'Date'[Date] = LatestYear
			        )
			    )
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: fbb73ed3-3514-498f-8851-ff106cd071f3

	measure 'Child Care Hourly Earnings Relative Latest' =
			
			VAR LatestYear = [Latest SEPH Year]
			RETURN
			    CALCULATE (
			        [Child Care Hourly Earnings Relative to All Industries],
			        FILTER (
			            ALL ( 'Date'[Date] ),
			            'Date'[Date] = LatestYear
			        )
			    )
		lineageTag: 2513404d-6aeb-480a-a678-51c1ecafa67a

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Child Care Hourly Earnings Gap Latest' =
			
			VAR LatestYear = [Latest SEPH Year]
			RETURN
			    CALCULATE (
			        [Child Care Hourly Earnings Gap],
			        FILTER (
			            ALL ( 'Date'[Date] ),
			            'Date'[Date] = LatestYear
			        )
			    )
		lineageTag: 8b348869-04d6-4b02-8295-d9860be40e9f

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Child Care Hourly Earnings 2019 Avg' =
			
			CALCULATE (
			    AVERAGEX (
			        VALUES ( 'Date'[Year] ),
			        [Child Care Avg Hourly Earnings]
			    ),
			    FILTER (
			        ALL ( 'Date' ),
			        'Date'[Year] = 2019
			    )
			)
		lineageTag: 2f4d77e4-0648-4602-9aee-5509cd971795

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'All Industries Hourly Earnings 2019 Avg' =
			
			CALCULATE (
			    AVERAGEX (
			        VALUES ( 'Date'[Year] ),
			        [All Industries Avg Hourly Earnings]
			    ),
			    FILTER (
			        ALL ( 'Date' ),
			        'Date'[Year] = 2019
			    )
			)
		lineageTag: ea6a6e85-7833-467d-bbef-b50a9669c34f

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Child Care Hourly Earnings Index 2019' =
			DIVIDE (
			    [Child Care Avg Hourly Earnings],
			    [Child Care Hourly Earnings 2019 Avg]
			) * 100
		formatString: 0.0
		lineageTag: 5f01307e-7eb8-4286-94e4-993f850635b5

	measure 'All Industries Hourly Earnings Index 2019' =
			DIVIDE (
			    [All Industries Avg Hourly Earnings],
			    [All Industries Hourly Earnings 2019 Avg]
			) * 100
		formatString: 0.0
		lineageTag: 7fad6e71-aabe-4713-9fa1-f4e907702e29

	measure 'Child Care Avg Hourly Earnings 3-Year Average' =
			
			AVERAGEX (
			    DATESINPERIOD (
			        'Date'[Date],
			        MAX ( 'Date'[Date] ),
			        -3,
			        YEAR
			    ),
			    [Child Care Avg Hourly Earnings]
			)
		lineageTag: 7683b82b-303a-40f9-8684-0d58cfd415fa

		annotation PBI_FormatHint = {"isGeneralNumber":true}

