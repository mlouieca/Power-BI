model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-CA
	dataAccessOptions
		fastCombine
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 1

annotation PBI_QueryOrder = ["CPS Monthly Labour Summary","Unzip","Canada LFS Monthly","Inflation Comparison"]

annotation PBI_ProTooling = ["DevMode"]

ref table 'CPS Monthly Labour Summary'
ref table 'Canada LFS Monthly'
ref table 'Labour Force Comparison'
ref table 'Inflation Comparison'
ref table Date
ref table 'Labour Force Indicator'

ref cultureInfo en-US

