		lineageTag: 67159b40-2502-4fd0-8b57-0ed76de46b55

	measure 'Participation Rate YoY Change (pp)' =
			
			VAR CurrentRate =
			    [Participation Rate (3MMA)]
			
			VAR PriorYearRate =
			    CALCULATE (
			        [Participation Rate (3MMA)],
			        DATEADD ( 'Date'[Date], -1, YEAR )
			    )
			
			RETURN
			    IF (
			        ISBLANK ( CurrentRate )
			            || ISBLANK ( PriorYearRate ),
			        BLANK (),
			        ( CurrentRate - PriorYearRate ) * 100
			    )
		formatString: 0.0
		lineageTag: a37ed7b6-175a-4a31-b526-1c5f8cac1256

	measure 'Employment Rate YoY Change (pp)' =
			
