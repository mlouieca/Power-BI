	measure 'Participation Rate Gap — Women vs Men, Young Child (pp)' =
			
			VAR WomenRate =
			    CALCULATE (
			        [Participation Rate (3MMA)],
			        REMOVEFILTERS (
			            'CPS Monthly Labour Summary'[Sex],
			            'CPS Monthly Labour Summary'[ChildStatus],
			            'CPS Monthly Labour Summary'[GroupLabel]
			        ),
			        'CPS Monthly Labour Summary'[Sex] = "Women",
			        'CPS Monthly Labour Summary'[ChildStatus] = "Co-resident child aged 0–5"
			    )
			
			VAR MenRate =
			    CALCULATE (
			        [Participation Rate (3MMA)],
			        REMOVEFILTERS (
			            'CPS Monthly Labour Summary'[Sex],
			            'CPS Monthly Labour Summary'[ChildStatus],
			            'CPS Monthly Labour Summary'[GroupLabel]
			        ),
			        'CPS Monthly Labour Summary'[Sex] = "Men",
			        'CPS Monthly Labour Summary'[ChildStatus] = "Co-resident child aged 0–5"
			    )
			
			RETURN
			    ( WomenRate - MenRate ) * 100
		formatString: 0.0
		lineageTag: de30317e-41c1-4774-b617-4a0ea6d4563d

