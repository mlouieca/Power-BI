		formatString: #,0
		lineageTag: 31a065fd-3705-4222-b9bf-a1d1ed55063c

	measure 'Labour Force (Weighted)' =
			
			[Employment (Weighted)] + [Unemployment (Weighted)]
		formatString: #,0
		lineageTag: 44c845b1-4cfd-4a3c-9f1d-361cce57e5b1

	measure 'Unweighted Sample Size' =
			
			SUM ( 'CPS Monthly Labour Summary'[UnweightedN] )
		formatString: 0
		lineageTag: e96e4dd4-9039-49a8-aa26-9c9d12152091

	measure 'Employment Rate (Calculated)' =
			
			DIVIDE (
			    [Employment (Weighted)],
			    [Population (Weighted)]
			)
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: c5efa187-7513-4877-818a-085ee7955306

	measure 'Participation Rate (Calculated)' =
			
			DIVIDE (
			    [Labour Force (Weighted)],
			    [Population (Weighted)]
			)
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: 5ca0489b-8547-42b9-80c1-394e35a887c5

	measure 'Unemployment Rate (Calculated)' =
			
			DIVIDE (
			    [Unemployment (Weighted)],
			    [Labour Force (Weighted)]
			)
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: 86ab8082-07fe-498b-8c81-fc9e743d4b1f

	measure 'Participation Rate (3MMA)' =
			
			VAR LastMonth =
			    MAX ( 'CPS Monthly Labour Summary'[ReferenceMonth] )
			
			VAR FirstMonth =
			    EDATE ( LastMonth, -2 )
			
			VAR MonthsAvailable =
			    CALCULATE (
			        DISTINCTCOUNT ( 'CPS Monthly Labour Summary'[ReferenceMonth] ),
			        REMOVEFILTERS ( 'Date' ),
			        DATESBETWEEN ( 'Date'[Date], FirstMonth, LastMonth )
			    )
			
			VAR LabourForce3M =
			    CALCULATE (
			        [Labour Force (Weighted)],
			        REMOVEFILTERS ( 'Date' ),
			        DATESBETWEEN ( 'Date'[Date], FirstMonth, LastMonth )
			    )
			
			VAR Population3M =
			    CALCULATE (
			        [Population (Weighted)],
			        REMOVEFILTERS ( 'Date' ),
			        DATESBETWEEN ( 'Date'[Date], FirstMonth, LastMonth )
			    )
			
			RETURN
			    IF (
			        ISBLANK ( LastMonth ) || MonthsAvailable < 3,
			        BLANK (),
			        DIVIDE ( LabourForce3M, Population3M )
			    )
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: 9fba5b5d-16ff-4443-bcea-36db349f5eae

	measure 'Employment Rate (3MMA)' =
			
			VAR LastMonth =
			    MAX ( 'CPS Monthly Labour Summary'[ReferenceMonth] )
			
			VAR FirstMonth =
			    EDATE ( LastMonth, -2 )
			
			VAR MonthsAvailable =
