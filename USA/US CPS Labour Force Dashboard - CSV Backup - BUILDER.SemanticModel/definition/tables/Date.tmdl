		annotation SummarizationSetBy = Automatic

	partition Date = calculated
		mode: import
		source =
				
				ADDCOLUMNS (
				    CALENDAR (
				        MIN ( 'CPS Monthly Labour Summary'[ReferenceMonth] ),
				        MAX ( 'CPS Monthly Labour Summary'[ReferenceMonth] )
				    ),
				    "Year", YEAR ( [Date] ),
				    "Month Number", MONTH ( [Date] ),
				    "Month Year", FORMAT ( [Date], "MMM yyyy" ),
				    "Month Sort", YEAR ( [Date] ) * 100 + MONTH ( [Date] ),
				    "Quarter Number", QUARTER ( [Date] ),
				    "Quarter", "Q" & QUARTER ( [Date] ),
				    "Quarter Year", "Q" & QUARTER ( [Date] ) & " " & YEAR ( [Date] ),
				    "Quarter Sort", YEAR ( [Date] ) * 10 + QUARTER ( [Date] )
				)

	annotation PBI_Id = c15c50553e744b27afb8ae448ac865fa

