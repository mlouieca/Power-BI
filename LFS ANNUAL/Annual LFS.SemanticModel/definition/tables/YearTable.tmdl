table YearTable
	lineageTag: 03916c35-0bfb-49cf-8f8d-6cc68eed8dbd

	column Year
		formatString: 0
		lineageTag: 03da8710-00e6-4698-8187-365cd99d298f
		summarizeBy: none
		isNameInferred
		sourceColumn: [Year]

		annotation SummarizationSetBy = Automatic

	column YearLabel
		lineageTag: 1656ff85-cbf3-459c-8928-1dcf5da65a3d
		summarizeBy: none
		isNameInferred
		sourceColumn: [YearLabel]

		annotation SummarizationSetBy = Automatic

	column REF_DATE
		formatString: 0
		lineageTag: 499b19eb-eb5e-41ba-aa5a-f2d68d9f941d
		summarizeBy: none
		isNameInferred
		sourceColumn: [REF_DATE]

		annotation SummarizationSetBy = Automatic

	partition YearTable = calculated
		mode: import
		source = ```
				
				VAR Years =
				    UNION(
				        SELECTCOLUMNS('LFS_FamilyStructure_14100396_Annual', "REF_DATE", 'LFS_FamilyStructure_14100396_Annual'[REF_DATE]),
				        SELECTCOLUMNS(LFS_Headline_14100327_Annual, "REF_DATE", LFS_Headline_14100327_Annual[REF_DATE]),
				        SELECTCOLUMNS(LFS_GenderWageGap_14100062, "REF_DATE", LFS_GenderWageGap_14100062[REF_DATE])
				    )
				RETURN
				ADDCOLUMNS(
				    DISTINCT(Years),
				    "Year", [REF_DATE],
				    "YearLabel", FORMAT(DATE([REF_DATE], 1, 1), "YYYY")
				)
				
				```

	annotation PBI_Id = 9705befa63714d40983621018d614543

