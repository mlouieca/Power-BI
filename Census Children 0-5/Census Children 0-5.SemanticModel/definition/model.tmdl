model Model
	culture: en-CA
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-CA
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_QueryOrder = ["Province","CSD","Indicator","Province Indicators","CSD Indicators","MIZ Summary","Notes","DataFolder","CensusChildrenData"]

annotation PBI_ProTooling = ["DevMode","MCP-PBIModeling"]

annotation __PBI_TimeIntelligenceEnabled = 1

ref table Province
ref table CSD
ref table Indicator
ref table 'Province Indicators'
ref table 'CSD Indicators'
ref table 'MIZ Summary'
ref table Notes

ref cultureInfo en-CA

