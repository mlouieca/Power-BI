	measure 'Participation Rate YoY (p.p.)' =
			
			VAR CurrentPR =
			    [Participation Rate (Monthly)]
			VAR PreviousYearPR =
			    CALCULATE(
			        [Participation Rate (Monthly)],
			        DATEADD(DateTable[Date], -1, YEAR)
			    )
			RETURN
			IF(
			    ISBLANK(CurrentPR) || ISBLANK(PreviousYearPR),
			    BLANK(),
			    CurrentPR - PreviousYearPR
			)
		lineageTag: 05f58f29-e7ae-449d-bad9-f19167394186

