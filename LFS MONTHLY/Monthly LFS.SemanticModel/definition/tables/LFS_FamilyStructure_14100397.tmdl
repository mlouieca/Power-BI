	measure 'Selected LFS Value YoY Change' =
			
			VAR CurrentValue =
			    [Selected LFS Value (Monthly)]
			VAR PreviousYearValue =
			    CALCULATE(
			        [Selected LFS Value (Monthly)],
			        DATEADD(DateTable[Date], -1, YEAR)
			    )
			RETURN
