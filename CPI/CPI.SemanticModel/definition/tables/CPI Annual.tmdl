	measure 'CPI Annual YoY Abs' = ```
			
			VAR CurrYear = [CPI Annual Index]
			VAR PrevYear =
			    CALCULATE (
			        [CPI Annual Index],
			        DATEADD ( 'Annual Dates'[Date], -1, YEAR )
			    )
			RETURN
			CurrYear - PrevYear
			
			```
