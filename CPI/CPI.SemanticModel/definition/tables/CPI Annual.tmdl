table 'CPI Annual'
	lineageTag: 08467b70-3518-4b8d-a5f1-ca9d1cf295f7

	measure 'CPI Annual Index' = ```
			
			AVERAGE ( 'CPI Annual'[VALUE] )
			
			```
		lineageTag: 042ad7e6-74e8-4ef6-a82e-a82b53132506

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'CPI Annual YoY %' = ```
			
			VAR CurrYear = [CPI Annual Index]
			VAR PrevYear =
			    CALCULATE (
			        [CPI Annual Index],
			        DATEADD ( 'Annual Dates'[Date], -1, YEAR )
			    )
			RETURN
			DIVIDE ( CurrYear - PrevYear, PrevYear )
			
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: e3d66310-8547-43e7-b787-e09e558936d1

	measure 'CPI Annual YoY % Avg 5 Years' = ```

			VAR LatestDateWithYoY =
			    MAXX (
			        FILTER (
			            ALLSELECTED ( 'Annual Dates'[Date] ),
			            NOT ISBLANK ( [CPI Annual YoY %] )
			        ),
			        'Annual Dates'[Date]
			    )
			VAR LastFiveAnnualDates =
			    TOPN (
			        5,
			        FILTER (
			            ALLSELECTED ( 'Annual Dates'[Date] ),
			            'Annual Dates'[Date] <= LatestDateWithYoY
			                && NOT ISBLANK ( [CPI Annual YoY %] )
			        ),
			        'Annual Dates'[Date],
			        DESC
			    )
			RETURN
			AVERAGEX ( LastFiveAnnualDates, [CPI Annual YoY %] )

			```
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: 9b7f0677-4f8a-42fd-87e9-a7221caf2f78

	measure 'CPI Annual YoY % Avg 10 Years' = ```

			VAR LatestDateWithYoY =
			    MAXX (
			        FILTER (
			            ALLSELECTED ( 'Annual Dates'[Date] ),
			            NOT ISBLANK ( [CPI Annual YoY %] )
			        ),
			        'Annual Dates'[Date]
			    )
			VAR LastTenAnnualDates =
			    TOPN (
			        10,
			        FILTER (
			            ALLSELECTED ( 'Annual Dates'[Date] ),
			            'Annual Dates'[Date] <= LatestDateWithYoY
			                && NOT ISBLANK ( [CPI Annual YoY %] )
			        ),
			        'Annual Dates'[Date],
			        DESC
			    )
			RETURN
			AVERAGEX ( LastTenAnnualDates, [CPI Annual YoY %] )

			```
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: 8a46c71e-73b8-402f-82df-c2553b24be0e

