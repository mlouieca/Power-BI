			```
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: e4585f1a-0d21-485e-8f9b-785d26cecf98

	measure 'CPI YoY Abs' = ```
			
			VAR CurrMonth = [CPI Index]
			VAR PrevYear =
			    CALCULATE (
			        [CPI Index],
			        DATEADD ( 'CPI'[REF_DATE], -1, YEAR )
			    )
			RETURN
			CurrMonth - PrevYear
			
			```
		formatString: 0.00
		lineageTag: c872ef4b-bcda-4556-a7bd-b874511e6884

	measure 'CPI YoY Abs (Latest)' = ```
			
