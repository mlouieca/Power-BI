	measure 'CPI YoY %' =
			
			VAR CurrKey =
			    MAX ( 'CPI'[YearMonthKey] )
			
			VAR CurrYear =
			    QUOTIENT ( CurrKey, 100 )
			
			VAR CurrMonth =
			    MOD ( CurrKey, 100 )
			
			VAR PrevKey =
			    ( CurrYear - 1 ) * 100 + CurrMonth
			
			VAR CurrVal =
			    [CPI Index]
			
			VAR PrevVal =
			    CALCULATE (
			        [CPI Index],
			        REMOVEFILTERS ( 'CPI'[MonthStart] ),
			        REMOVEFILTERS ( 'CPI'[REF_DATE] ),
			        REMOVEFILTERS ( 'CPI'[YearMonthKey] ),
			        'CPI'[YearMonthKey] = PrevKey
			    )
			
			RETURN
			DIVIDE ( CurrVal - PrevVal, PrevVal )
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 58d885d6-8ca4-4a41-b441-1fa8a83aabc3

	measure 'CPI YoY % (Latest)' = ```
			
			VAR LatestDate =
			    MAX ( 'CPI'[REF_DATE] )
			RETURN
			CALCULATE (
			    [CPI YoY %],
			    'CPI'[REF_DATE] = LatestDate
