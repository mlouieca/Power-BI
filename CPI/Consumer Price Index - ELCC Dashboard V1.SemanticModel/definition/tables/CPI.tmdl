			```
		formatString: 0.00
		lineageTag: 4761d5c4-2243-4442-bfd4-4cc7d1dccc44

	measure 'CPI Previous Year Index - Debug' =
			
			VAR CurrKey =
			    MAX ( 'CPI'[YearMonthKey] )
			
			VAR CurrYear =
			    QUOTIENT ( CurrKey, 100 )
			
			VAR CurrMonth =
			    MOD ( CurrKey, 100 )
			
			VAR PrevKey =
			    ( CurrYear - 1 ) * 100 + CurrMonth
			
			RETURN
			CALCULATE (
			    [CPI Index],
			    FILTER (
			        ALL ( 'CPI'[YearMonthKey], 'CPI'[MonthStart], 'CPI'[REF_DATE] ),
			        'CPI'[YearMonthKey] = PrevKey
			    )
			)
		lineageTag: 8b1422e0-817f-404e-b70c-b61ea9aff144

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'CPI PrevKey - Debug' =
			
			VAR CurrKey =
			    MAX ( 'CPI'[YearMonthKey] )
			
			VAR CurrYear =
			    QUOTIENT ( CurrKey, 100 )
			
			VAR CurrMonth =
			    MOD ( CurrKey, 100 )
			
			RETURN
			( CurrYear - 1 ) * 100 + CurrMonth
		formatString: 0
