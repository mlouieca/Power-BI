table CPI
	lineageTag: c02d0ce5-fd2f-4ab5-a127-1b394ca9056e

	measure 'CPI 12M MA' = ```
			
			AVERAGEX (
			    DATESINPERIOD ( 'CPI'[REF_DATE], MAX ( 'CPI Weights'[REF_DATE] ), -12, MONTH ),
			    [CPI Index]
			)
			
			```
		lineageTag: c9cc4dfa-d93a-4500-b742-7e44591e8755

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'CPI Index' = ```
			
			AVERAGE ( 'CPI'[VALUE] )
			
			```
		lineageTag: dce13896-d62e-4e3b-9568-77071913c997

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'CPI Index (Latest)' = ```
			
			VAR LatestDate =
			    MAX ( 'CPI'[REF_DATE] )
			RETURN
			CALCULATE (
			    [CPI Index],
			    'CPI'[REF_DATE] = LatestDate
			)
			
			```
		formatString: 0.00
		lineageTag: dd1076c0-ec30-4493-b1c8-d4066f4c98c2

	measure 'CPI MoM %' = ```
			
			VAR CurrMonth = [CPI Index]
			VAR PrevMonth =
			    CALCULATE (
			        [CPI Index],
			        DATEADD ( 'CPI'[REF_DATE], -1, MONTH )    )
			RETURN
			DIVIDE ( CurrMonth - PrevMonth, PrevMonth )
			
			```
		lineageTag: 7a1e3d2d-5328-48e4-9f98-e45d644cdfbb

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'CPI MoM % (Latest)' = ```
			
			VAR LatestDate =
