table 'CPI Weights'
	lineageTag: 3a4f2e6c-9e2b-4c96-9f5e-45e2d055e116

	measure 'CPI Weight %' =
			DIVIDE ( AVERAGE ( 'CPI Weights'[VALUE] ), 100 )
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 76e1fb0b-1b88-4d72-a790-e5e03ea1e492

	measure 'CPI Weight % (Latest)' =
			VAR LatestWeightYear =
				CALCULATE (
					MAX ( 'CPI Weights'[REF_DATE] ),
					REMOVEFILTERS ( 'CPI Weights'[REF_DATE] )
				)
			RETURN
				CALCULATE (
					[CPI Weight %],
					'CPI Weights'[REF_DATE] = LatestWeightYear
				)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 13384b56-8cb8-48e6-9d7b-9a345337c5bb

	measure 'Child Care CPI Weight % (Latest)' =
			CALCULATE (
				[CPI Weight % (Latest)],
				KEEPFILTERS ( 'CPI Weights'[Products and product groups] = "Child care services" )
			)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: bc11cf06-65a5-49bd-8cf0-9af550a63d8a

	measure 'Child Care CPI Weight Change (pp)' =
			VAR LatestWeightYear =
				CALCULATE (
					MAX ( 'CPI Weights'[REF_DATE] ),
					REMOVEFILTERS ( 'CPI Weights'[REF_DATE] )
				)
			VAR PreviousWeightYear =
				CALCULATE (
					MAX ( 'CPI Weights'[REF_DATE] ),
					REMOVEFILTERS ( 'CPI Weights'[REF_DATE] ),
					'CPI Weights'[REF_DATE] < LatestWeightYear
				)
			VAR LatestWeight =
				CALCULATE (
					[CPI Weight %],
					KEEPFILTERS ( 'CPI Weights'[Products and product groups] = "Child care services" ),
					'CPI Weights'[REF_DATE] = LatestWeightYear
				)
			VAR PreviousWeight =
				CALCULATE (
					[CPI Weight %],
					KEEPFILTERS ( 'CPI Weights'[Products and product groups] = "Child care services" ),
					'CPI Weights'[REF_DATE] = PreviousWeightYear
				)
			RETURN
				( LatestWeight - PreviousWeight ) * 100
		formatString: 0.00 "pp";-0.00 "pp";0.00 "pp"
		lineageTag: f9e0ca21-31c8-48f0-899c-2a785e914381

	measure 'Child Care CPI Index' =
			VAR SelectedGeographies = VALUES ( 'CPI Weights'[GEO] )
			RETURN
				CALCULATE (
					[CPI Index],
					KEEPFILTERS ( 'CPI'[Products and product groups] = "Child care services" ),
					TREATAS ( SelectedGeographies, 'CPI'[GEO] )
				)
		formatString: 0.00
		lineageTag: 6f5bdaf0-a9fc-4f57-8aea-f1a34be143f3

	measure 'Child Care CPI Index (Latest)' =
			VAR SelectedGeographies = VALUES ( 'CPI Weights'[GEO] )
			RETURN
				CALCULATE (
					[CPI Index (Latest)],
					KEEPFILTERS ( 'CPI'[Products and product groups] = "Child care services" ),
					TREATAS ( SelectedGeographies, 'CPI'[GEO] )
				)
		formatString: 0.00
		lineageTag: 1a663da8-396f-4fd9-bd96-26e2317f8d33

	measure 'Child Care CPI YoY % (Latest)' =
			VAR SelectedGeographies = VALUES ( 'CPI Weights'[GEO] )
			RETURN
				CALCULATE (
					[CPI YoY % (Latest)],
					KEEPFILTERS ( 'CPI'[Products and product groups] = "Child care services" ),
					TREATAS ( SelectedGeographies, 'CPI'[GEO] )
				)
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: 0b492b62-925d-4b10-9706-f5ab8bb73c10

	measure 'Child Care CPI Contribution (pp)' =
			[Child Care CPI Weight % (Latest)]
				* [Child Care CPI YoY % (Latest)]
				* 100
		formatString: 0.00 "pp";-0.00 "pp";0.00 "pp"
		lineageTag: 085d82e8-8c12-4774-a2d9-1e7537a1d70d

	column REF_DATE
		dataType: int64
		formatString: 0
		lineageTag: 99cdd019-2165-4e9f-99c9-1d728f21e0eb
		summarizeBy: none
		sourceColumn: REF_DATE

		annotation SummarizationSetBy = Automatic

	column GEO
