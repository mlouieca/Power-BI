					#"Filtered Rows" = Table.SelectRows(#"Changed Type", each [REF_DATE] >= 2002 and [#"Price period of weight"] = "Weight at basket link month prices" and [#"Geographic distribution of weight"] = "Distribution to selected geographies"),
