		lineageTag: 5e08a7d1-1542-4a6f-954e-e785eb2df2b5
		summarizeBy: none
		sourceColumn: GEO

		annotation SummarizationSetBy = Automatic

	column 'Products and product groups'
		dataType: string
		lineageTag: 9fd526e9-a57f-4ef2-9b66-3dc058a6565f
		summarizeBy: none
		sourceColumn: Products and product groups

		annotation SummarizationSetBy = Automatic

	column VALUE
		dataType: double
		lineageTag: c3f3e087-2952-41d2-98a8-770b7b63ad69
		summarizeBy: sum
		sourceColumn: VALUE

		annotation SummarizationSetBy = Automatic

	column 'Price period of weight'
		dataType: string
		lineageTag: 437dff5e-7139-4126-bc28-3b790d7c95b6
		summarizeBy: none
		sourceColumn: Price period of weight

		annotation SummarizationSetBy = Automatic

	column 'Geographic distribution of weight'
		dataType: string
		lineageTag: 11e8de9e-73fe-4d43-97fc-8ce8db0fd9d2
		summarizeBy: none
		sourceColumn: Geographic distribution of weight

		annotation SummarizationSetBy = Automatic

